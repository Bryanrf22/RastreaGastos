<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
            xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
            x:Class="RastreaGastos.MainPage">

    <Grid RowDefinitions="Auto, Auto, *" RowSpacing="10" Padding="20">
        <SearchBar x:Name="Busqueda" Placeholder="Buscar gasto..." TextChanged="OnSearchTextChanged" />

        <Button
            Grid.Row="1"
            Text="Agregar Gasto"
            Clicked="OnAgregarGasto"
            Background="#10B981"
            TextColor="White" />

        <CollectionView x:Name="ListaGastos" Grid.Row="2" SelectionMode="Single">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="8" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackLayout>
                            <Label Text="{Binding Descripcion}" FontAttributes="Bold" FontSize="16"></Label>
                            <Label Text="{Binding Monto, StringFormat='${0:C}'}" FontSize="14"></Label>
                        </StackLayout>
                        <Button Text="Eliminar" Clicked="OnEliminarGasto" Grid.Column="1" Background="#DC2626" TextColor="White"></Button>
                        <Button Text="Editar" Clicked="OnEditarGasto" Grid.Column="2" Background="#3B82F6" TextColor="White"></Button>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>

</ContentPage>
